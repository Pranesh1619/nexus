generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("SALES") // ADMIN, SALES
  status    String   @default("ACTIVE") // ACTIVE, INACTIVE
  companyId String?
  phone     String?
  leads     Lead[]
  calls     CallLog[]
  otpCode   String?
  otpExpires DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String?
  company     String?
  status      String   @default("NEW") // NEW, CONTACTED, QUALIFIED, WON, LOST
  source      String?  // WEBSITE, REFERRAL, COLD_CALL
  assignedTo  String?
  salesPerson User?    @relation(fields: [assignedTo], references: [id])
  calls       CallLog[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([phone, assignedTo])
}

model CallLog {
  id                    String   @id @default(cuid())
  jobId                 String?
  callerPhone           String?
  receiverPhone         String?
  startTime             DateTime @default(now())
  endTime               DateTime?
  duration              Int?     // in seconds
  status                String   @default("CONNECTED") // CONNECTED, MISSED, VOICEMAIL
  stage                 String   @default("New Lead")  // New Lead, Attempted Contact, Connected, Engaged, Interested, Qualified, Follow-up Needed, Closed
  transcript            String?  // JSON or text transcript
  translatedText        String?  // Translated text from call
  detectedVoiceLanguage String?  // Voice language detected
  translatedLanguage    String?  // Target language translated to
  wordCount             Int?     // Word count of transcript
  analysis              String?  // AI Analysis summary
  aiScore               Int?     @default(0) // 0-100 score
  notes                 String?
  audioUrl              String?
  leadId                String
  userId                String
  lead                  Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
}

model ZohoConfig {
  id           String   @id @default("default_zoho_config")
  clientId     String
  clientSecret String
  refreshToken String
  accessToken  String
  updatedAt    DateTime @updatedAt
}

model SipTrunkConfig {
  id                String   @id @default("default_sip_config")
  domain            String   // SIP domain / gateway host (e.g. phone.provider.com)
  webSocketUrl      String   // WebSocket connection URL for WebRTC SIP client (e.g. wss://phone.provider.com/ws)
  username          String
  password          String
  callerId          String   // Outbound caller ID number (e.g. +1234567890)
  codec             String   @default("OPUS") // OPUS, G711_ULAW, G711_ALAW
  isActive          Boolean  @default(true)
  mockTwilioUrl     String?  // Optional self-hosted mock Twilio server URL (e.g. http://localhost:5050)
  telephonyProvider String   @default("TWILIO") // TWILIO or PLIVO
  plivoAuthId       String?  @default("")
  plivoAuthToken    String?  @default("")
  plivoAppSid       String?  @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}


